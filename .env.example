# Copy this file to .env and fill in your keys
# Never commit .env to version control

# LLM API Keys (use whichever you prefer)
OPENAI_API_KEY= 
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Optional structured LLM mode.
# Keep TRIAGE_USE_LLM=0 for deterministic final runs.
TRIAGE_USE_LLM=0
TRIAGE_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=12
TRIAGE_LLM_MAX_FAILURES=3

# Optional: Embedding model keys
COHERE_API_KEY=
VOYAGE_API_KEY=
